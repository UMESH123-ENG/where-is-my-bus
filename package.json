{
  "name": "bus-tracker",
  "version": "1.0.0",
  "description": "Real-time Haryana Roadways Bus Tracking System",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build":"npm install",
    "prod": "cross-env NODE_ENV=production node server.js",
    "seed:stops": "node scripts/seedStops.js",
    "seed:routes": "node scripts/createRoutes.js",
    "seed:all": "npm run seed:stops && npm run seed:routes"
  },
  "keywords": [
    "bus",
    "tracking",
    "realtime",
    "haryana",
    "roadways"
  ],
  "author": "Your Name",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.0",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "nodemon": "^3.1.14"
  }
}
